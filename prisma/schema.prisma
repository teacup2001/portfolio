// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 枚举定义
enum MediaType {
  IMAGE
}

enum EmbedType {
  VIDEO
  AUDIO
}

// 用户表（管理员）
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt 加密
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 网站配置表（所有可编辑文本）
model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique // 如：site_title, nav_home
  value     String   // 文本内容
  group     String   // 分组：general, nav, home, work, about, footer
  label     String   // 后台显示的名称
  updatedAt DateTime @updatedAt

  @@map("site_config")
}

// 分类表（支持树形结构）
model Category {
  id        String   @id @default(cuid())
  name      String   // 分类名称
  slug      String   @unique // URL 友好标识
  sortOrder Int      @default(0)
  parentId  String?  // 父分类 ID，null 表示大类
  parent    Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Category[] @relation("CategoryHierarchy")
  works     Work[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

// 作品表
model Work {
  id          String      @id @default(cuid())
  title       String      // 作品标题
  slug        String      @unique // URL 友好标识
  date        DateTime    // 作品日期
  textBody    String?     // 文本正文（纯文本）
  sortOrder   Int         @default(0)
  categoryId  String      // 所属分类
  category    Category    @relation(fields: [categoryId], references: [id])
  medias      Media[]     // 图片文件（第一张作预览图）
  embeds      Embed[]     // 嵌入代码（视频/音频）
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("works")
}

// 图片文件表（上传到服务器）
model Media {
  id          String   @id @default(cuid())
  workId      String   // 所属作品
  work        Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  url         String   // 文件 URL（/uploads/xxx.jpg）
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("medias")
}

// 嵌入代码表（视频/音频）
model Embed {
  id        String     @id @default(cuid())
  workId    String     // 所属作品
  work      Work       @relation(fields: [workId], references: [id], onDelete: Cascade)
  type      EmbedType  // 嵌入类型：VIDEO / AUDIO
  title     String?    // 标题（可选）
  embedCode String     // 嵌入代码（iframe 或通用链接）
  sortOrder Int        @default(0)

  @@map("embeds")
}

